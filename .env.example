ASTRAFLOW_API_KEY=replace_with_your_astraflow_api_key
# Optional override. The config file can also set api_base_url per platform.
ASTRAFLOW_API_BASE_URL=https://api.modelverse.cn/v1/chat/completions
# Optional: path to a custom CA bundle, useful behind an enterprise HTTPS proxy.
# ASTRAFLOW_CA_BUNDLE=/path/to/company-ca-bundle.pem
# Last-resort local debugging only. Prefer ASTRAFLOW_CA_BUNDLE.
# ASTRAFLOW_VERIFY_SSL=false
